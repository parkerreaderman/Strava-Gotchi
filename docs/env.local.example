# Copy this file to .env.local (same project root). Never commit .env.local.
#
# Strava OAuth (https://www.strava.com/settings/api)
# - Client ID may be public (NEXT_PUBLIC_*).
# - Client secret is SERVER-ONLY — never prefix with NEXT_PUBLIC_ or expose it to the browser.
# - Do NOT paste "Your Access Token" / "Your Refresh Token" from Strava's developer page here.
#   Those are personal API tokens. This app uses OAuth; each user gets tokens via "Connect with Strava".
#
NEXT_PUBLIC_STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/api/auth/callback

DATABASE_URL="file:./dev.db"

# Optional — monitoring / CI
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
